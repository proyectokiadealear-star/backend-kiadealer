# ─────────────────────────────────────────────
# KIA DEALER BACKEND — Variables de Entorno
# Copia este archivo como .env y rellena los valores
# ─────────────────────────────────────────────

# Puerto del servidor (default: 3000)
PORT=3000

# ──── FIREBASE ────────────────────────────────
# Obtenidos desde Firebase Console → Configuración del proyecto → Cuentas de servicio
FIREBASE_PROJECT_ID=kia-dealer-prod
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@kia-dealer-prod.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_CLAVE_AQUI\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=kia-dealer-prod.appspot.com

# ──── ALGORITMO DE PREDICCIÓN ─────────────────
# Umbral mínimo (0-100) para incluir una predicción de accesorio
PREDICTION_THRESHOLD=40

# ──── ENTORNO ────────────────────────────────
NODE_ENV=development

# ──── SERVICIOS EXTERNOS ─────────────────────
# ETL microservice (FastAPI) — used by ExcelService to process Excel KDCS files
PYTHON_SERVICE_URL=http://localhost:8000

# ──── CORS ────────────────────────────────────
# Orígenes permitidos separados por coma. Sin esta variable solo permite localhost.
# En producción (Render): https://tu-frontend.vercel.app
CORS_ORIGIN=http://localhost:3001
